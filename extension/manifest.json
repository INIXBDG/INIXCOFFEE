{
  "manifest_version": 3,
  "name": "INIXCOFFEE Notif Proxy Background",
  "version": "1.0",
  "description": "Background fetcher for notifications, forwards to page to avoid polluting page network tab.",
  "permissions": [
    "scripting",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:8000/*"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "favicon.ico",
    "32": "favicon.ico",
    "180": "icon/apple-touch-icon-180x180.png"
  }
}
